# Port for the REST API
PORT=3000

# Optional. If set, every protected endpoint requires header: X-API-Key: <value>
API_KEY=

# Where incoming WhatsApp messages are forwarded (POST JSON). Leave empty to disable.
WEBHOOK_URL=

# Auto-konversi nomor lokal berawalan 0 ke format internasional.
# Contoh "62": "08114100444" -> "628114100444". Kosong = nomor harus sudah internasional.
DEFAULT_COUNTRY_CODE=

# Comma-separated events to forward. Currently: message. Use "*" for all.
WEBHOOK_EVENTS=message

# Directory for the SQLite session store
STORE_DIR=./data

# Download incoming media and include it as base64 in the webhook payload
DOWNLOAD_MEDIA=true

# Skip downloading media larger than this many bytes (default 200MB)
MAX_DOWNLOAD_BYTES=209715200

# --- Penyimpanan riwayat pesan ---
# Simpan pesan masuk & keluar ke tabel gw_messages (default mati untuk privasi).
# Aktifkan untuk memakai endpoint GET /messages.
STORE_MESSAGES=false
# Hapus otomatis pesan yang lebih tua dari N hari (0 = simpan selamanya).
MESSAGE_RETENTION_DAYS=0

# --- Kirim massal (bulk) ---
# Jeda acak antar-pesan (anti-ban). Default body request bisa menimpa nilai ini.
BULK_MIN_DELAY_MS=3000
BULK_MAX_DELAY_MS=6000

# --- API Key Management (managed keys) ---
# Default untuk key baru yang dibuat lewat /admin/keys (bisa ditimpa per-key).
# Batas request per window (0 = tanpa batas).
DEFAULT_RATE_LIMIT=0
# Panjang window rate limit dalam detik.
DEFAULT_RATE_WINDOW_SEC=60
# Batas jumlah session/device yang boleh dibuat sebuah key (0 = tanpa batas).
DEFAULT_MAX_SESSIONS=0

# --- Webhook delivery queue (retry/backoff) ---
# Number of concurrent webhook delivery workers
WEBHOOK_WORKERS=4
# Max buffered messages before new ones are dropped
WEBHOOK_QUEUE_SIZE=1000
# Number of retries after the first failed attempt (total tries = retries + 1)
WEBHOOK_MAX_RETRIES=3
# Base backoff in milliseconds (exponential: base, base*2, base*4, ...)
WEBHOOK_BACKOFF_MS=2000

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
